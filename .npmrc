# node-linker=hoisted is Expo's official monorepo recommendation.
# https://docs.expo.dev/guides/monorepos/
#
# Defends against the legacy expo/AppEntry.js fallback path failing in
# pnpm symlink layouts (KIT_RETROSPECTIVE.md B3).
node-linker=hoisted

# Stricter peer-dep handling — surface mismatches instead of silently
# installing a wrong version.
strict-peer-dependencies=false
auto-install-peers=true
